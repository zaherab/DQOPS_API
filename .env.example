# Application
APP_NAME=DQ Platform
DEBUG=false
API_PREFIX=/api/v1

# Database (TimescaleDB)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/dq_platform
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Security
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
API_KEY_HEADER=X-API-Key
# Comma-separated API keys. Empty = dev mode (any non-empty key accepted).
# VALID_API_KEYS=key1,key2,key3

# CORS
# Comma-separated allowed origins. Default: * (all).
# CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com

# Rate limiting
# RATE_LIMIT_DEFAULT=100/minute

# Execution
CHECK_EXECUTION_TIMEOUT=300
MAX_CONCURRENT_CHECKS=10
